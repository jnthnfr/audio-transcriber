# Backend secrets / config — copy to backend/.env for local dev.
# In production (Render), set these in the service's Environment tab.

# Required for the OpenAI Whisper API backend
OPENAI_API_KEY=

# Path to Google Cloud service account JSON (required for Google Cloud STT)
GOOGLE_APPLICATION_CREDENTIALS=

# Whisper local config
WHISPER_CACHE_DIR=./models
DEFAULT_WHISPER_MODEL=base

# Upload + processing limits
MAX_UPLOAD_SIZE_MB=500
MAX_CONCURRENT_CHUNKS=1

# Job temp file directory
TEMP_DIR=./backend/temp

# Allowed CORS origins (comma-separated). Add your Render frontend URL in prod.
# e.g. http://localhost:5173,https://audio-transcriber-web.onrender.com
FRONTEND_ORIGIN=http://localhost:5173

# Hugging Face access token — required for speaker diarization (pyannote.audio).
# Create a free read token at https://huggingface.co/settings/tokens and
# accept the model license at https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
